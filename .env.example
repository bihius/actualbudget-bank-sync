# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will NOT be committed

# Enable Banking application UUID (from https://enablebanking.com/control-panel)
ENABLE_BANKING_APP_ID=your-enable-banking-app-uuid

# Path to your RSA private key inside the container (leave as-is if using default volume mount)
ENABLE_BANKING_KEY_PATH=/keys/private.pem

# Actual Budget server URL (use container hostname if running in the same Docker network)
ACTUAL_SERVER_URL=http://actual:5006

# Actual Budget server password
ACTUAL_PASSWORD=your-actual-server-password

# Actual Budget budget sync ID (visible in More → Settings → Show advanced settings)
ACTUAL_SYNC_ID=your-budget-sync-id

# Public base URL for OAuth callback — must be reachable by Enable Banking servers
# Register https://your-domain.com/auth/callback in your Enable Banking app settings
REDIRECT_BASE_URL=https://your-domain.com

# Cron schedule for automatic sync (default: every 6 hours)
SYNC_CRON=0 */6 * * *

# Port to listen on
PORT=3000
